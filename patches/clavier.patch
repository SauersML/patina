# Filament v3 — the lead, electric ITSELF this time. Clavinet lineage,
# not Wurlitzer: a narrow pulse plucked through a fast resonant filter
# ping, high-passed so the bite sits forward. Still a KEYED envelope
# (nothing sustains, so nothing reads as a string), drive 2.8 for wire
# and current, resonance 1.1 for the squelch edge. No LFO of any kind.
waveform 1
pulse_width 0.22
osc2_wave 2
osc2_pitch 0
osc2_level 0.15
osc3_wave 0
osc3_pitch 0
osc3_level 0
detune 2
sub 0.15
circuit 1
key_track 0.8
osc_fm 0
sync 0
ring 0
glide 0
attack 0.002
decay 0.8
sustain 0.2
release 0.25
filter_env 1.6
filter_attack 0.001
filter_decay 0.16
filter_sustain 0.25
filter_release 0.2
cutoff 1200
resonance 1.1
drive 2.8
saturation 1.15
hpf 80
volume 0.5
octave 4
noise 0
fuzz 0
spring 0.12
lfo_rate 0.5
lfo_shape 0.5
lfo_pitch 0
lfo_filter 0
lfo_pwm 0
