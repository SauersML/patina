decay 0.4
sustain 0.7
release 0.12
filter_env 0.8
filter_attack 0.003
filter_decay 0.18
filter_sustain 0.45
filter_release 0.15
cutoff 700
resonance 0.5
drive 2.6
saturation 1.05
hpf 25
volume 0.5
