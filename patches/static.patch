# Knotwork — the stab, from the circuit: a RESONANCE ZAP. The whole
# event is a filter gesture: cutoff starts at 500, the envelope hurls
# it +2.5 octaves and lets it fall in 90 ms through a ladder ringing
# at res 2.6 — every harmonic of the narrow pulse gets rung and
# dropped as the peak sweeps past. Nothing sustains (amp sustain 0);
# the stab IS its sweep. No sync, no ring, no imitation available.
waveform 1
pulse_width 0.15
osc2_wave 0
osc2_pitch 0
osc2_level 0
osc3_wave 0
osc3_pitch 0
osc3_level 0
detune 2
sub 0.1
circuit 1
key_track 0.6
osc_fm 0
sync 0
ring 0
glide 0
attack 0.002
decay 0.25
sustain 0.0
release 0.12
filter_env 2.5
filter_attack 0.001
filter_decay 0.09
filter_sustain 0.0
filter_release 0.1
cutoff 500
resonance 2.6
drive 1.8
saturation 1.0
hpf 120
volume 0.5
octave 4
noise 0
fuzz 0
spring 0.18
lfo_rate 0.5
lfo_shape 0.5
lfo_pitch 0
lfo_filter 0
lfo_pwm 0
