# the roll, compressed: 4.5 beats at the very end, not a 4-bar ramp
track roll kit=909 len=0.25 vel=0.9
>138 SD:0.5@0.5 SD:0.5@0.55 SD:0.5@0.6 SD:0.5@0.65 (SD@0.7)x4 (SD@0.8)x4 (SD@0.9)x2 R:1.5 [SD CP]@1

# rim funk + ghost snares
track perc kit=909 len=0.5 vel=0.5
>80 (R:1.5 RS:0.5@0.5 R:1 RS:0.25@0.45 SD:0.25@0.25 R:0.5)x3
>160 (R:1.5 RS:0.5@0.5 R:1.75 SD:0.25@0.3)x12

