# ---- ring-bell echo answers in the breather
track bell patch=glintbell vel=0.5 len=0.5
>80 R:2 C5:0.75 A4:0.75@0.45 E5:0.5 R:6 A4:0.75 G4:0.75@0.45 A4:0.5@0.55
# two strikes doubling the bloom's landings: the Cmaj7 arrival, the E7
>120 E5:1@0.45 R:3 B4:2@0.4

# ---- the sync scream: one held note, osc2 climbing 19 semitones
# written 20.7 so gate 0.7 holds it exactly 14.5 beats: the note-off
# IS the gap
track riser patch=syncscream vel=0.85 len=1
>128 A3:20.7

