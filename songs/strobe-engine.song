# ---- the memory: bocuma (SH-101 voice) sings the hook at half speed
# before the song exists, and again after it's gone
track memory patch=bocuma vel=0.6 len=1
A3:1.5 C4:0.5@0.5 A3:2 E4:1 D4:1@0.55 C4:1 A3:1 G3:1.5@0.5 A3:4.5 R:2
>96 C5:3@0.5 B4:1@0.45 A4:3@0.5 G4:1@0.45 E4:2@0.5 G4:1 A4:1 B4:4@0.55 C5:3@0.5 D5:1 B4:2@0.5 G4:2@0.45 E5:1.5@0.55 D5:1.5@0.5 B4:1 G#4:4@0.5
>216 D4:1.5 C4:1.5@0.55 B3:1 G3:1@0.5 A3:4 E4:1@0.5 A3:6@0.55

