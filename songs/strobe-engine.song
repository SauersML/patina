[A2 E3 A3 C4 E4 B4]:14@0.85

# ---- bass: no octave bounce. Offbeat-only pump between the kicks in
# act one; a one-register roller with accent waves in drop 2. Passing
# tones only at phrase ends. Tacet in the bloom.
track bass patch=rawbass vel=0.9 len=0.5
>32 ((R A1@0.85)x8 (R F1@0.85)x4 (R G1@0.85)x3 R E1@0.85)x3
(R A1@0.85)x8 (R F1@0.85)x4
# alone: the walkdown into the bloom
>92 A1:1@0.8 G1:1@0.8 F1:1@0.8 E1:1@0.85
