0.002
automate filter_decay
0.16
automate filter_sustain
0.0
automate filter_release
0.12
automate circuit
1
automate hpf
40
automate tape_drive
0.35
automate tape_age
0.4
automate spring
0.25
automate reverb_wet
0.12
automate reverb_decay
0.3

