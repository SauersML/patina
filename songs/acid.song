# Grid Runner — a 140 bpm acid machine. The sequence mutates every pass,
# the resonance climbs the whole song like a rising floor, and halfway
# through the germanium fuzz kicks the door in.

bpm 140
gate 0.55

automate waveform
2
automate sub
0.4
automate attack
0.005
automate decay
0.18
automate sustain
0.25
automate release
0.12
