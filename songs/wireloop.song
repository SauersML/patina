  BD:1 SD:0.5 BD:1.25 BD:0.25 SD:0.25 BD:0.75
  BD:0.5 BD:0.25 BD:0.75 BD:1.5 SD:1
  BD:1 SD:0.6667 BD:1 BD:0.3333 SD:0.3333 BD:0.6667
  BD:0.6667 BD:0.3333 SD:0.6667 BD:0.6667 SD:1@0.35 SD:0.3333@0.5 BD:0.3333@0.5
  >P5
  BD:1 SD:0.5 BD:0.75 SD:0.25 BD:0.25 BD:0.25 SD:0.25 BD:0.5 BD:0.25
  BD:0.5 BD:0.25 BD:0.75 BD:0.75 SD:0.25 BD:0.25 BD:0.25 SD:0.25 BD:0.5 BD:0.25
  BD:1 SD:0.5 BD:1.25 BD:0.25 SD:0.25 BD:0.75
  R:1 SD:0.5 BD:1.5 SD:0.25 BD:0.75
  BD:1 SD:0.5 BD:1 BD:0.25 BD:0.25 SD:0.75 BD:0.25
