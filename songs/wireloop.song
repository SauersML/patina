  BD:1 SD:0.5 BD:1.5 SD:0.25 BD:0.75
  BD:1.5 BD:1.5 SD:1
  BD:1 SD:0.5 BD:1.5 SD:1
  BD:1.5 BD:1.5 SD:1
  R:0.5 BD:0.5 SD:0.5 BD:1.5 SD:1
  BD:1.5 BD:2.5
  >CODA
  BD:4
  R:4
  SD:0.3333@0.12 SD:0.3333@0.2 SD:0.3333@0.27 SD:1@0.33 SD:0.3333@0.15 SD:0.3333@0.21 SD:0.3333@0.27 SD:0.3333@0.33 SD:0.3333@0.39 SD:0.3333@0.45

