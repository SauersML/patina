# Ferris Wheel — a fairground waltz. Oom-pah-pah below, a music box
# above, and halfway around the wheel the whole fairground lifts a minor
# third — then eases back down to earth and the lights come on.

bpm 100
gate 0.8

automate waveform
1
automate pulse_width
0.3
automate lfo_rate
0.5
automate lfo_pwm
0.25
automate osc2_wave
0
automate osc2_pitch
12
automate osc2_level
0.4
automate detune
8
automate attack
0.006
automate decay
0.5
automate sustain
0.5
automate release
0.45
automate filter_env
1.8
automate filter_attack
0.002
automate filter_decay
0.4
automate filter_sustain
0.3
automate filter_release
0.4
automate cutoff
3200
automate resonance
0.8
automate chorus_mode
2
automate chorus_depth
0.4
automate reverb_decay
0.55
automate reverb_wet
0.35
automate tape_wow
0.1
automate tape_flutter
0.06
automate tape_age
0.2

track oompah vel=0.62 len=0.85
C3:1 [E4 G4]:1 [E4 G4]:1 | A2:1 [E4 A4]:1 [E4 A4]:1 | F2:1 [F4 A4]:1 [F4 A4]:1 | G2:1 [F4 G4 B4]:1 [F4 G4 B4]:1
