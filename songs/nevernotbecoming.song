# ---- the bee itself: no voice, pure circuit ---------------------------
# Three saws detuned 28 cents beat against each other at A3 — 220 Hz,
# a honeybee's actual wingbeat — with per-voice noise as wing-air and
# a jittering 16th-note micro-melody under 80 ms glide: hover, wander,
# leave. It crosses the stereo field on entry and recedes downward.
track buzz vel=0.55 len=0.25
  R:1
  A3:0.75 G#3:0.25 A3:0.5 A#3:0.25 A3:0.75 G#3:0.5 A3:0.5 B3:0.25 A3:0.75 G#3:0.25 A3:0.5 A#3:0.25 A3:0.75 G#3:0.5 A3:1.25
  R:427
  A3:0.5 G#3:0.5 A3:0.75 G3:0.25 F#3:0.75 G3:0.25 F#3:0.5 E3:0.5 F#3:0.25 E3:0.75 E3:1 D3:0.5 E3:1.5

automate buzz.detune
  28
automate buzz.osc2_level
  0.8
automate buzz.osc3_level
  0.8
automate buzz.noise
  0.12
automate buzz.sub
  0.3
automate buzz.drive
  3
automate buzz.saturation
  0.6
automate buzz.cutoff
  2600
automate buzz.attack
  0.05
automate buzz.release
  0.3
automate buzz.glide
  0.08
automate buzz.gain
  1.7 R:436 0.4:8@exp
automate buzz.pan
  -0.5 R:8 0.5:8@lin R:420 -0.6:8@lin

