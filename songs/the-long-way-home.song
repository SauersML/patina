# The Long Way Home — wistful but forward-moving.
#
# The feeling is carried by craft, not gimmicks: Fmaj9 -> Em7 -> Dm9 ->
# Cmaj7, the bass walking down F E D C under major-7 color — longing
# that keeps walking. Swung boom-bap with ghost snares, the bass locked
# to the kick's steps, chords leaning an 8th ahead of every barline
# (the push track), everything ducking gently off the kick. 88 BPM.
#
# Form (beats): INTRO 16 | GROOVE 32 | VERSE (melody A) 32 | SPOT
#   (the kit talks) 16 | PEAK (melody B + pad) 32 | BREAK 16 |
#   RETURN (melody A, home now) 32 | OUT (Cmaj7 resolves) 16  = 192

bpm 88
gate 0.92

section INTRO   0..16
section GROOVE  16..48
section VERSE   48..80
section SPOT    80..96
section PEAK    96..128
section BREAK   128..144
section RETURN  144..176
section OUT     176..192

# ---- the deck and the room ------------------------------------------
automate tape_wow
  0.35
automate tape_flutter
  0.1
automate tape_age
  0.45
automate tape_drive
  0.22
automate reverb_wet
  0.28
automate reverb_decay
  0.7
automate chorus_mode
  1
automate chorus_depth
  0.3

# ---- drums -----------------------------------------------------------
automate bd_tune
  0.42
automate bd_decay
  0.55
automate bd_sweep
  0.5
automate bd_drive
  0.3
automate sd_tune
  0.35
automate sd_tone
  0.5
automate sd_snappy
  0.55
automate sd_decay
  0.45
automate hh_level
  0.5 >BREAK 0.36 >RETURN 0.5
automate oh_decay
  0.45
automate dr_drive
  0.2

track beat kit=909 len=0.25 vel=0.9 swing=0.6
  >GROOVE
  (BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:1 BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:0.25 BD:0.25@0.7 R:0.5)x3
  BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:1
  BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 R:0.25 SD:0.25@0.5 SD:0.25@0.65 SD:0.25@0.8 SD:0.25@0.95
  >VERSE
  (BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:1 BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:0.25 BD:0.25@0.7 R:0.5)x3
  BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:1
  BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 R:0.25 SD:0.25@0.5 SD:0.25@0.65 SD:0.25@0.8 SD:0.25@0.95
  >SPOT
  (BD:0.5 RS:0.25@0.5 R:0.25 SD:0.75 BD:0.5@0.8 RS:0.25@0.6 BD:0.25@0.95 SD:0.25@0.3 SD:0.75 RS:0.25@0.55 BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:0.25 BD:0.25@0.7 SD:0.25@0.35 RS:0.25@0.5)x2
  >PEAK
  (BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:1 BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:0.25 BD:0.25@0.7 R:0.5)x3
  BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:1
  BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 R:0.25 SD:0.25@0.5 SD:0.25@0.65 SD:0.25@0.8 SD:0.25@0.95
  >RETURN
  (BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:1 BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:0.25 BD:0.25@0.7 R:0.5)x3
  BD:0.75 R:0.25 SD:0.75 BD:0.75@0.8 BD:0.25@0.95 SD:0.25@0.3 SD:1
  BD:0.75@0.7 R:0.25 SD:0.75@0.6 BD:0.75@0.5 R:2

track hats kit=909 len=0.25 vel=0.8 swing=0.62
  >GROOVE
  ((CH@0.75 CH@0.35 CH@0.55 CH@0.4)x7 CH@0.7 CH@0.35 OH:0.5@0.6)
  (CH@0.75 CH@0.35 CH@0.55 CH@0.4)x7 CH@0.7 CH@0.35 OH:0.5@0.6
